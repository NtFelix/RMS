# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# PostHog Analytics (Optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Stripe (Optional)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Internal API Configuration
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_WORKER_URL=
NEXT_PUBLIC_BASE_URL=
NEXT_PUBLIC_MIETEVO_MCP_URL=

# PostHog SDK (Server-side, Optional)
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_HOST=

# Pins Server Action IDs so they stay stable across builds/deploys. Without it,
# Next.js generates a random key per build and stale clients hit
# "Failed to find Server Action" mid-deploy. Set the SAME value at build and
# runtime and keep it stable across deploys. Generate with: openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Resend (Email) - Required for invitation emails
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL="Mietevo <service@mietevo.de>"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (Server-side, Optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
